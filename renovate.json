{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Group dependency updates by manager",
      "matchPackageNames": ["*"],
      "groupName": "{{manager}} dependencies",
      "groupSlug": "{{manager}}",
      "separateMajorMinor": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update terraform_version pinned in IaC workflow files",
      "fileMatch": ["^\\.github/workflows/.*\\.yaml$"],
      "matchStrings": [
        "terraform_version:\\s*['\"]?(?<currentValue>\\d+\\.\\d+\\.\\d+)['\"]?"
      ],
      "depNameTemplate": "hashicorp/terraform",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ]
}
